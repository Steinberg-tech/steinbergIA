# App
APP_ENV=development
APP_NAME=SAC AI
DEBUG=false

# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Database
DATABASE_URL=postgresql+asyncpg://sac:sac@localhost:5432/sac_ai

# Redis
REDIS_URL=redis://localhost:6379/0

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ERP
ERP_BASE_URL=
ERP_API_KEY=

# CRM
CRM_BASE_URL=
CRM_API_KEY=

# Projuris
PROJURIS_BASE_URL=https://apigw.projurisadv.com.br
PROJURIS_SERVICE_URL=https://service.projurisadv.com.br
PROJURIS_USERNAME=usuario@dominio.com$$tenant
PROJURIS_PASSWORD=sua_senha
PROJURIS_CLIENT_ID=api_cliente_codigo_XXXXXX
PROJURIS_CLIENT_SECRET=sua_client_secret
